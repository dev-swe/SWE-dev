<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title}" Height="800" Width="1500"
        ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F4"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <!-- ── Brand colors ─────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BrandGreen"      Color="#12413C"/>
        <SolidColorBrush x:Key="BrandGreenHover" Color="#1a5c55"/>
        <SolidColorBrush x:Key="BrandGreenLight" Color="#e8f0ef"/>
        <SolidColorBrush x:Key="RevBGColor"      Color="#FFEEEEEE"/>
        <SolidColorBrush x:Key="BorderGray"      Color="#D0D0D0"/>
        <SolidColorBrush x:Key="SurfaceWhite"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedText"       Color="#666666"/>

        <!-- Shared label width -->
        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib"
                       x:Key="LabelWidth">96</system:Double>

        <!-- ── TextBox style ─────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="6,0,6,0"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{StaticResource SurfaceWhite}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox style ────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="6,0,4,0"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="{StaticResource SurfaceWhite}"/>
        </Style>

        <!-- ── Standard button style ─────────────────────────────────────── -->
        <Style x:Key="StdButton" TargetType="Button">
            <Setter Property="Height"           Value="26"/>
            <Setter Property="Padding"          Value="10,0,10,0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderGray}"/>
            <Setter Property="Background"       Value="{StaticResource SurfaceWhite}"/>
            <Setter Property="Foreground"       Value="#333333"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="{StaticResource BrandGreenLight}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                <Setter Property="Foreground"  Value="{StaticResource BrandGreen}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandGreen}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Print button style ────────────────────────────────────────── -->
        <Style x:Key="PrintButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BrandGreen}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandGreenHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0d2e2a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section card style ────────────────────────────────────────── -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource SurfaceWhite}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="12,10,12,12"/>
            <Setter Property="Margin"           Value="0,8,0,0"/>
        </Style>

        <!-- ── Section header TextBlock ──────────────────────────────────── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="{StaticResource BrandGreen}"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- ── Row label style ───────────────────────────────────────────── -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Width"             Value="{StaticResource LabelWidth}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="#444444"/>
        </Style>

        <!-- ── Pill RadioButton (color mode) ─────────────────────────────── -->
        <Style x:Key="PillRadio" TargetType="RadioButton">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="Foreground"      Value="{StaticResource BrandGreen}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="pill"
                                Background="White"
                                BorderBrush="{StaticResource BorderGray}"
                                BorderThickness="1"
                                CornerRadius="13"
                                Padding="12,4,12,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background"  Value="{StaticResource BrandGreen}"/>
                                <Setter TargetName="pill" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                <Setter Property="Foreground" Value="#F1E1C0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                <Setter TargetName="pill" Property="Background"  Value="{StaticResource BrandGreenLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid cell styles ───────────────────────────────────────── -->
        <Style x:Key="DefaultColumnStyle" TargetType="DataGridCell">
            <Setter Property="ToolTip"      Value="{Binding tooltip}"/>
            <Setter Property="ContextMenu"  Value="{DynamicResource ItemContextMenu}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding printable}" Value="False">
                    <Setter Property="Foreground" Value="#bdbdbd"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Cell templates ────────────────────────────────────────────── -->
        <ControlTemplate x:Key="Default" TargetType="DataGridCell">
            <StackPanel Background="White">
                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                      Columns="{TemplateBinding GridView.ColumnCollection}"/>
            </StackPanel>
        </ControlTemplate>

        <ControlTemplate x:Key="NonPrintableSheet" TargetType="DataGridCell">
            <StackPanel Background="#f6f6f6">
                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                      Columns="{TemplateBinding GridView.ColumnCollection}"/>
            </StackPanel>
        </ControlTemplate>

        <DataTemplate x:Key="RevisionCell">
            <StackPanel x:Name="revinfo" VerticalAlignment="Center" Orientation="Horizontal">
                <Border Background="{StaticResource RevBGColor}" CornerRadius="3,0,0,3"
                        MinWidth="16" Margin="2,2,0,2" Padding="5,0,5,0">
                    <TextBlock Text="{Binding revision.date}" Foreground="Black"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="{StaticResource RevBGColor}" MinWidth="16"
                        Margin="0,2,0,2" Padding="5,0,5,0"
                        BorderBrush="LightGray" BorderThickness="1,0,1,0">
                    <TextBlock Text="{Binding revision.number}" Foreground="Black"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Border>
                <Border Background="{StaticResource RevBGColor}" CornerRadius="0,3,3,0"
                        MinWidth="16" Padding="5,0,5,0" Margin="0,2,0,2">
                    <TextBlock Text="{Binding revision.desc}" Foreground="Black"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding revision.is_set}" Value="False">
                    <Setter TargetName="revinfo" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="PrintSettingCell">
            <StackPanel x:Name="psettinginfo" VerticalAlignment="Center" Orientation="Horizontal">
                <Border Background="{StaticResource RevBGColor}" CornerRadius="3"
                        Margin="2,2,0,2" Padding="5,0,5,0">
                    <TextBlock x:Name="psettingname" Text="{Binding print_settings.Name}"
                               Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding read_only}" Value="True">
                    <Setter TargetName="psettingname" Property="Foreground" Value="Gray"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style TargetType="Hyperlink">
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="TextBlock.TextDecorations" Value="{x:Null}"/>
        </Style>

        <!-- ── Print icon ─────────────────────────────────────────────────── -->
        <Canvas x:Key="printIcon" Width="28" Height="28">
            <Path Canvas.Top="4" Canvas.Left="4"
                  Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z"
                  Fill="White">
                <Path.LayoutTransform>
                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                </Path.LayoutTransform>
            </Path>
        </Canvas>

        <DataTemplate x:Key="printSettingsItem">
            <WrapPanel>
                <TextBlock x:Name="sizeName" Text="{Binding name}"/>
                <Border x:Name="incompatibleMarker" Background="#E53935"
                        Height="18" Margin="8,0,0,0" CornerRadius="3">
                    <TextBlock HorizontalAlignment="Left" Padding="5,0,5,0"
                               Text="{DynamicResource IncompatibleWithPrinter}"
                               FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                </Border>
            </WrapPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding is_compatible}" Value="True">
                    <Setter TargetName="incompatibleMarker" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="sizeName"           Property="Foreground"  Value="Black"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding is_compatible}" Value="False">
                    <Setter TargetName="incompatibleMarker" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="sizeName"           Property="Foreground"  Value="Gray"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Background="#F4F4F4">

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Height="26" Background="{StaticResource BrandGreen}">
            <TextBlock Foreground="White" Margin="10,0,0,0" MouseDown="handle_url_click">
                <Hyperlink NavigateUri="https://github.com/McCulloughRT/PrintFromIndex"
                           Click="handle_url_click">
                    <Run Text="{DynamicResource KudosToRyan}"/>
                </Hyperlink>
            </TextBlock>
        </StatusBar>

        <!-- ── Top control panel ─────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="12,10,12,0">

            <!-- Document / Index selectors + Print button -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCard}" Grid.Column="0" Margin="0,0,8,0" Padding="12,8,12,8">
                    <StackPanel>
                        <!-- Model row -->
                        <DockPanel Height="26">
                            <Border Background="{StaticResource BrandGreen}" CornerRadius="4"
                                    Padding="10,0,14,0" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource Model}" Foreground="White"
                                           FontWeight="Medium" VerticalAlignment="Center"/>
                            </Border>
                            <ComboBox x:Name="documents_cb" SelectionChanged="doclist_changed">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock x:Name="docname" Text="{Binding name}"/>
                                            <TextBlock x:Name="docname_linked" Visibility="Collapsed">
                                                <Run Text="{DynamicResource LinkedPrefix}"/>
                                                <Run Text="{Binding name}"/>
                                            </TextBlock>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding linked}" Value="True">
                                                <Setter TargetName="docname"        Property="Visibility" Value="Hidden"/>
                                                <Setter TargetName="docname_linked" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>
                        <!-- Sheet Index row -->
                        <DockPanel Height="26" Margin="0,6,0,0">
                            <ComboBox x:Name="schedules_cb" SelectionChanged="sheetlist_changed">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Print button -->
                <Button x:Name="print_b" Grid.Column="1"
                        Style="{StaticResource PrintButton}"
                        Content="{StaticResource printIcon}"
                        Margin="0,8,0,0"
                        Click="print_sheets"
                        ToolTip="Print selected sheets"/>
            </Grid>

            <!-- Options row: Sheet Ordering + Sheet Printing -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Sheet Ordering card ───────────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Grid.Column="0" Margin="0,8,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SheetOrdering}"
                                   Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="reverse_cb" IsChecked="False"
                                  Click="options_changed"
                                  Content="{DynamicResource ReversePrintOrder}"/>

                        <StackPanel x:Name="order_sp" Margin="0,8,0,0">
                            <!-- Sheet Lookup -->
                            <DockPanel Margin="0,6,0,0" Height="26">
                                <TextBlock Text="Sheet Lookup"
                                           Style="{StaticResource RowLabel}"/>
                                <TextBox x:Name="sheetsearch_tb" Margin="8,0,0,0"
                                         TextChanged="sheet_search_changed"/>
                            </DockPanel>
                        </StackPanel>

                            <!-- Revision Filter -->
                            <DockPanel Margin="0,6,0,0" Height="26">
                                <TextBlock Text="Revision Filter"
                                           Style="{StaticResource RowLabel}"/>
                                <ComboBox x:Name="revfilter_cb" Margin="8,0,0,0"
                                          SelectionChanged="rev_filter_changed"/>
                            </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ── Sheet Printing card ───────────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Grid.Column="1" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SheetPrinting}"
                                   Style="{StaticResource SectionHeader}"/>

                        <!-- Combine / DWG toggles -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="combine_cb" Margin="0,0,32,0"
                                      IsChecked="False"
                                      Checked="options_changed" Unchecked="options_changed"
                                      Content="{DynamicResource CombineIntoOnePDF}"/>
                            <CheckBox x:Name="export_dwg"
                                      IsChecked="False"
                                      Checked="options_changed" Unchecked="options_changed"
                                      Content="{DynamicResource ExportDWG}"/>
                        </StackPanel>


                        <!-- Color Mode pills -->
                        <DockPanel Margin="0,0,0,10" Height="28">
                            <TextBlock Text="Color Mode" Style="{StaticResource RowLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                <RadioButton x:Name="colormode_blackline"
                                             GroupName="ColorMode" IsChecked="True"
                                             Style="{StaticResource PillRadio}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="blText" Text="Standard"
                                                   FontWeight="Bold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=""
                                                   FontSize="11" Foreground="{StaticResource MutedText}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="colormode_color"
                                             GroupName="ColorMode"
                                             Style="{StaticResource PillRadio}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="fcText" Text="Color"
                                                   FontWeight="Bold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=""
                                                   FontSize="11" Foreground="{StaticResource MutedText}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="colormode_bw"
                                             GroupName="ColorMode"
                                             Style="{StaticResource PillRadio}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="bwText" Text="Black &amp;White"
                                                   FontWeight="Bold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=""
                                                   FontSize="11" Foreground="{StaticResource MutedText}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </DockPanel>

                        <!-- ADD THIS BLOCK ↓ — Combined PDF Name (visible only when Combine is checked) -->
                        <DockPanel x:Name="combined_pdf_name_dp" Margin="0,0,0,10" Height="26"
                                   Visibility="Collapsed">
                            <TextBlock Text="Combined Name"
                                       Style="{StaticResource RowLabel}" />
                            <TextBox x:Name="combined_pdf_name_tb"
                                     Margin="8,0,0,0"
                                     TextWrapping="NoWrap"
                                     ToolTip="Leave blank to use the Revit document title" />
                        </DockPanel>


                        <!-- Export Folder -->
                        <DockPanel Margin="0,0,0,6" Height="26">
                            <TextBlock Text="Export Folder" Style="{StaticResource RowLabel}"/>
                            <Button Content="Browse…" Width="72"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource StdButton}"
                                    Margin="6,0,0,0"
                                    Click="choose_export_folder"/>
                            <TextBox x:Name="exportfolder_tb"
                                     IsReadOnly="True"
                                     Margin="8,0,0,0"
                                     TextWrapping="NoWrap"/>
                        </DockPanel>

                        <!-- Naming Format -->
                        <DockPanel x:Name="namingformat_dp" Margin="0,6,0,0" Height="26">
                            <TextBlock Text="{DynamicResource NamingFormat}"
                                       Style="{StaticResource RowLabel}"/>
                            <Button Content="{DynamicResource EditFormats}"
                                    Width="100" DockPanel.Dock="Right"
                                    Style="{StaticResource StdButton}"
                                    Margin="6,0,0,0"
                                    Click="edit_formats"/>
                            <ComboBox x:Name="namingformat_cb"
                                      FontFamily="Consolas"
                                      Margin="8,0,0,0"
                                      SelectionChanged="options_changed">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Padding="4,1,4,1">
                                                <TextBlock Text="{Binding name}">
                                                    <TextBlock.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Copy naming format"
                                                                      Click="copy_naming_format"/>
                                                        </ContextMenu>
                                                    </TextBlock.ContextMenu>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>

                        <!-- Printer -->
                        <DockPanel Margin="0,6,0,0" Height="26">
                            <TextBlock Text="{DynamicResource Printer}"
                                       Style="{StaticResource RowLabel}"/>
                            <ComboBox x:Name="printers_cb" Margin="8,0,0,0"
                                      SelectionChanged="printers_changed"/>
                        </DockPanel>

                        <!-- Page Settings -->
                        <DockPanel Margin="0,6,0,0" Height="26">
                            <TextBlock Text="{DynamicResource PageSettings}"
                                       Style="{StaticResource RowLabel}"/>
                            <ComboBox x:Name="printsettings_cb" Margin="8,0,0,0"
                                      SelectionChanged="sheetlist_changed"
                                      ItemTemplate="{StaticResource printSettingsItem}"/>
                        </DockPanel>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- Sheets list header + error/guide -->
            <StackPanel Margin="0,10,0,4">
                <TextBlock TextWrapping="WrapWithOverflow"
                           Text="{DynamicResource ListOfSheets}"
                           Foreground="#444444"/>
                <Border x:Name="errormsg_block" Background="#E53935" CornerRadius="4"
                        Padding="8,5,8,5" Margin="0,5,0,5" Visibility="Collapsed">
                    <TextBlock x:Name="errormsg_tb" Foreground="White" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="varsizeguide" Padding="8" Background="{StaticResource BrandGreen}"
                        CornerRadius="4" Margin="0,5,0,5" Visibility="Collapsed">
                    <DockPanel>
                        <DockPanel x:Name="sheetopts_wp" DockPanel.Dock="Right" IsEnabled="False">
                            <DockPanel DockPanel.Dock="Bottom">
                                <Button DockPanel.Dock="Right" Height="26" Width="130"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource StdButton}"
                                        Content="{DynamicResource SetPrintSettings}"
                                        Click="set_sheet_printsettings"/>
                                <Button DockPanel.Dock="Left" Height="26" Width="130"
                                        Style="{StaticResource StdButton}"
                                        Content="{DynamicResource ResetPrintSettings}"
                                        Click="sheetlist_changed"/>
                            </DockPanel>
                            <Grid/>
                        </DockPanel>
                        <Expander Header="{DynamicResource Guide}" Foreground="White" Cursor="Help">
                            <TextBlock Margin="5,5,0,0" TextWrapping="Wrap"
                                       Foreground="White"
                                       Text="{DynamicResource GuideText}"/>
                        </Expander>
                    </DockPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ── Sheet DataGrid ────────────────────────────────────────────── -->
        <DataGrid x:Name="sheets_lb"
                  AutoGenerateColumns="False"
                  Margin="12,0,12,10"
                  BorderBrush="{StaticResource BorderGray}"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  CanUserSortColumns="True"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EBEBEB"
                  VerticalGridLinesBrush="#EBEBEB"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  SelectionChanged="sheet_selection_changed">

            <DataGrid.Resources>
                <ContextMenu x:Key="ItemContextMenu">
                    <MenuItem Header="{DynamicResource CopySheetFileNames}"
                              Click="copy_filenames"/>
                </ContextMenu>
            </DataGrid.Resources>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"       Value="{StaticResource BrandGreen}"/>
                    <Setter Property="Foreground"       Value="White"/>
                    <Setter Property="FontWeight"       Value="SemiBold"/>
                    <Setter Property="FontSize"         Value="12"/>
                    <Setter Property="Padding"          Value="8,6,8,6"/>
                    <Setter Property="BorderBrush"      Value="{StaticResource BrandGreenHover}"/>
                    <Setter Property="BorderThickness"  Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{StaticResource SheetNumber}"
                                    Binding="{Binding number}"
                                    MinWidth="100" Width="100"
                                    IsReadOnly="True"
                                    CellStyle="{StaticResource DefaultColumnStyle}"/>
                <DataGridTextColumn Header="{StaticResource SheetName}"
                                    Binding="{Binding name}"
                                    MinWidth="400" Width="400"
                                    IsReadOnly="True"
                                    CellStyle="{StaticResource DefaultColumnStyle}"/>
                <DataGridTemplateColumn Header="{StaticResource SheetRevision}"
                                        MinWidth="50" Width="1*"
                                        IsReadOnly="True"
                                        CellTemplate="{StaticResource RevisionCell}"
                                        SortMemberPath="revision_date_sortable"/>
                <DataGridTemplateColumn x:Name="psettingcol"
                                        Header="{StaticResource PrintSetting}"
                                        MinWidth="50" Width="*"
                                        IsReadOnly="True"
                                        CellTemplate="{StaticResource PrintSettingCell}"
                                        Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="pfilename"
                                    Header="{StaticResource FileName}"
                                    FontFamily="Consolas"
                                    Binding="{Binding print_filename}"
                                    MinWidth="50" Width="2*"
                                    IsReadOnly="True"
                                    CellStyle="{StaticResource DefaultColumnStyle}"
                                    Visibility="Collapsed"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
